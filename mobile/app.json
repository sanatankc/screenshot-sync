{
  "expo": {
    "name": "Captr",
    "slug": "capture-mobile",
    "scheme": "captr",
    "version": "0.0.1-alpha.5",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#090b10"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.sanatan.screenshotsync",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "getcaptr.vercel.app",
              "pathPrefix": "/open"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "POST_NOTIFICATIONS"
      ],
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#090b10"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-dev-client",
      "expo-sqlite",
      "expo-notifications",
      [
        "expo-camera",
        {
          "cameraPermission": "Captr uses your camera to scan pairing codes."
        }
      ]
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "e17eb6ab-d43c-41e4-b277-d0e01e1b5155"
      }
    },
    "owner": "sanatankc"
  }
}
