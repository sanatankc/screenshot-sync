{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "@cloudflare/workers-types",
      "@cloudflare/vitest-pool-workers"
    ],
    "baseUrl": ".",
    "paths": {
      "@server/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "drizzle.config.ts",
    "test/**/*.ts",
    "test/**/*.d.ts"
  ]
}
