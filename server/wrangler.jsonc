{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "capture-server",
  "main": "src/index.ts",
  "compatibility_date": "2025-09-06",
  "vars": {
    "ALLOWED_ORIGINS": "http://localhost:3001,http://127.0.0.1:3001"
  },
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "screenshot-sync-db",
      "database_id": "replace-with-d1-id"
    }
  ],
  "r2_buckets": [
    {
      "binding": "SCREENSHOT_ASSETS",
      "bucket_name": "screenshot-sync-assets"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "WORKSPACE_HUB",
        "class_name": "WorkspaceHub"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "WorkspaceHub"
      ]
    }
  ],
  "queues": {
    "producers": [
      {
        "binding": "RETENTION_CLEANUP_QUEUE",
        "queue": "screenshot-sync-retention"
      }
    ]
  },
  "env": {
    "production": {
      "name": "capture-server-production",
      "vars": {
        "ALLOWED_ORIGINS": "https://capture-shot.vercel.app,http://localhost:3001,http://127.0.0.1:3001"
      },
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "screenshot-sync-db-production",
          "database_id": "87373a38-4aab-4b4a-ae0b-47655763a763"
        }
      ],
      "r2_buckets": [
        {
          "binding": "SCREENSHOT_ASSETS",
          "bucket_name": "screenshot-sync-assets-production"
        }
      ],
      "durable_objects": {
        "bindings": [
          {
            "name": "WORKSPACE_HUB",
            "class_name": "WorkspaceHub"
          }
        ]
      },
      "queues": {
        "producers": [
          {
            "binding": "RETENTION_CLEANUP_QUEUE",
            "queue": "screenshot-sync-retention-production"
          }
        ]
      }
    }
  }
}
